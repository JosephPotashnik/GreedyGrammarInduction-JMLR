{
  // These runs use sample sentences as the source and infer identity preterminals directly from sample tokens.
  "ProgramsToRun": [
    {
      "InputParams": {
        "SourceOfTruth": "Samples",
        "LexiconSource": "IdentityFromTokens",
        "MaxSentenceLength": 10,
        "SamplesFileName": "AMBNCNANBNCMSamples.txt"
      },
      "SearchSpaceParams": {
        "MaxNumberOfNonTerminals": 15,
        "MaxNumberOfRules": 20,
        "MaxDepthBetweenSubSolutions": 3,
        "MaxDepthAfterMinimalGlobal": 2,
        "MinSizeOfOptimalSubSolution": 3
      },
      "PostLearnerVerification": {
        "ResultsContainGrammarWeaklyEquivalentTo": "AMBNCNANBNCM.txt",
        "ComparisonMode": "SurfaceTokens",
        "TargetLexiconFileName": "ClassicalLexicon.json"
      }
    }
  ]
}
