{
  // These runs use sample sentences as the source and infer identity preterminals directly from sample tokens.
  "ProgramsToRun": [
    {
      "InputParams": {
        "SourceOfTruth": "Samples",
        "LexiconSource": "IdentityFromTokens",
        "MaxSentenceLength": 6,
        "SamplesFileName": "Dyck4Samples.txt"
      },
      "SearchSpaceParams": {
        "MaxNumberOfNonTerminals": 11,
        "MaxNumberOfRules": 16,
        "MaxDepthBetweenSubSolutions": 2,
        "MaxDepthAfterMinimalGlobal": 1,
        "MinSizeOfOptimalSubSolution": 2
      },
      "PostLearnerVerification": {
        "ResultsContainGrammarWeaklyEquivalentTo": "Dyck4.txt",
        "ComparisonMode": "SurfaceTokens",
        "TargetLexiconFileName": "ClassicalLexicon.json"
      }
    },
